      "final_yaml": "nika: workflow@0.12\nworkflow: competitor-shipment-research\ndescription: \"Researches a competitor's recent shipments using web fetches and returns structured findings with sources, while bounding cost.\"\nmodel: claude-sonnet-4-20250514\ntasks:\n  - id: search_competitor_news\n    invoke:\n      tool: \"novanet::novanet_search\"\n      params:\n        query: \"ExampleTech Q2 2026 product launches OR shipments OR releases\"\n        limit: 5\n\n  - id: fetch_articles\n    depends_on: [search_competitor_news]\n    for_each: \"{{$search_competitor_news.results | pluck('url')}}\"\n    invoke:\n      tool: \"nika:fetch\"\n      params:\n        url: \"{{with.item}}\"\n        extract: article\n\n  - id: extract_findings\n    depends_on: [fetch_articles]\n    with:\n      articles: \"{{$fetch_articles.results}}\"\n    infer:\n      prompt: |\n        Based ONLY on the provided articles about ExampleTech's recent shipments or product announcements,\n        identify each distinct product or significant feature that was shipped or announced this quarter.\n        For each finding, provide a concise name, a brief description of what was shipped or announced,\n        and the exact URL of the source article.\n        If the articles do not contain any relevant shipment or announcement information, return an empty list.\n\n        Articles (in JSON format):\n        {{with.articles | to_json}}\n      output:\n        format: json\n"
