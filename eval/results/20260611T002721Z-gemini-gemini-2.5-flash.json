      "final_yaml": "nika: v1\nworkflow: blog-to-newsletter\ndescription: \"Takes a blog post file and produces a newsletter-friendly version, saved next to the original.\"\nmodel: claude-sonnet-4-20250514\n\ntasks:\n  - id: read_blog_post\n    exec:\n      command: \"cat {{inputs.blog_post_path | shell}}\"\n\n  - id: generate_newsletter_content\n    depends_on: [read_blog_post]\n    with:\n      blog_content: $read_blog_post\n    provider: anthropic\n    model: claude-sonnet-4-20250514\n    infer:\n      prompt: |\n        You are an expert content creator specializing in marketing and newsletters.\n        Read the following blog post carefully. Your task is to condense it into\n        a concise, engaging, and highly readable version suitable for an email\n        newsletter.\n\n        Focus on:\n        1.  Highlighting the main topic and its core message.\n        2.  Extracting 2-3 key takeaways or actionable insights.\n        3.  Maintaining a positive, informative, and inviting tone.\n        4.  Keeping the length to approximately 200-300 words.\n        5.  Avoiding jargon where possible, or explaining it simply.\n        6.  Suggesting a clear call to action if appropriate (e.g., \"Read the full post here\").\n\n        Do not include an introduction or conclusion that references this prompt.\n        Just provide the newsletter content directly.\n\n        Blog Post Content:\n        ---\n        {{with.blog_content}}\n        ---\n      max_tokens: 1000\n\n  - id: save_newsletter_file\n    depends_on: [generate_newsletter_content]\n    with:\n      newsletter_content: $generate_newsletter_content\n      original_path: \"{{inputs.blog_post_path}}\"\n      output_dir: \"{{with.original_path | split('/') | initial | join('/')}}\"\n      original_filename: \"{{with.original_path | split('/') | last}}\"\n      newsletter_filename: \"{{with.original_filename | replace('.md', '_newsletter.md')}}\"\n      full_output_path: \"{{with.output_dir}}/{{with.newsletter_filename}}\"\n      resolved_output_path: >-\n        {{ (with.output_dir == '') ? with.newsletter_filename : with.full_output_path }}\n\n    exec:\n      command: \"echo {{with.newsletter_content | shell}} > {{with.resolved_output_path | shell}}\"\n"
    },
