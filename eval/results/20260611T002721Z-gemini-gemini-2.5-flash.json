      "final_yaml": "nika:\n  version: v1 # Based on user instruction \"nika: v1\"\n  inputs: # Moved inputs under 'nika' as it's not allowed at the root\n    billing_api_url: \"https://api.example.com/invoices\"\n    last_processed_file_path: \"last_processed_invoice.txt\"\n\nworkflow: process-new-invoices\ndescription: \"Fetches invoices and processes only those new since the last run.\"\n\ntasks:\n  - id: read_last_processed_id\n    exec:\n      command: \"cat {{nika.inputs.last_processed_file_path}} 2>/dev/null || echo '0'\"\n  - id: fetch_all_invoices\n    depends_on: [read_last_processed_id]\n    invoke:\n      tool: nika:fetch\n      args:\n        url: \"{{nika.inputs.billing_api_url}}\"\n        method: GET\n        extract: jsonpath\n        jsonpath: \"$\"\n  - id: filter_new_invoices\n    depends_on: [fetch_all_invoices]\n    with:\n      all_invoices: \"{{$fetch_all_invoices.result}}\"\n      last_processed_id: \"{{$read_last_processed_id.result | trim | to_number}}\"\n    invoke:\n      tool: nika:jq\n      args:\n        query: 'map(select(.id > $last_id_val))'\n        input: \"{{with.all_invoices | to_json}}\"\n        vars:\n          last_id_val: \"{{with.last_processed_id}}\"\n  - id: process_each_new_invoice\n    depends_on: [filter_new_invoices]\n    for_each:\n      items: \"{{$filter_new_invoices.result}}\"\n      as: new_invoice\n      concurrency: 5\n    exec: # 'exec' verb is now a direct child of the task, sibling to 'for_each'\n      command: \"echo 'New Invoice to Process: ID={{with.new_invoice.id}}, Amount={{with.new_invoice.amount}}'\"\n  - id: determine_new_max_id\n    depends_on: [filter_new_invoices]\n    with:\n      filtered_invoices: \"{{$filter_new_invoices.result}}\"\n      current_last_id: \"{{$read_last_processed_id.result | trim | to_number}}\"\n    invoke:\n      tool: nika:jq\n      args:\n        query: 'if . | length > 0 then map(.id) | max else $current_last_id_val end'\n        input: \"{{with.filtered_invoices | to_json}}\"\n        vars:\n          current_last_id_val: \"{{with.current_last_id}}\"\n  - id: write_new_last_processed_id\n    depends_on: [process_each_new_invoice, determine_new_max_id]\n    exec:\n      command: \"echo '{{$determine_new_max_id.result | trim}}' > {{nika.inputs.last_processed_file_path}}\"\n"
