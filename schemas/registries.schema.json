      }
    },
    "tombstones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tombstoneRow"
      }
    },
    "projections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/projectionRow"
      }
    },
    "migrations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/migrationRow"
      }
    }
  },
